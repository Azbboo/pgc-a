# PGC trading system local configuration.
# Copy this file to .env and fill secrets locally. Do not commit real tokens.

PGC_DB_PATH=data/pgc_trading.db
PGC_DATA_DIR=data
PGC_REPORTS_DIR=reports

# Tushare token must be supplied by environment variable at runtime.
TUSHARE_TOKEN=

# Default paper account used by local CLI workflows.
PGC_DEFAULT_ACCOUNT_KEY=paper-main
PGC_DEFAULT_ACCOUNT_NAME=paper_200k
PGC_INITIAL_CASH=200000
PGC_MAX_POSITIONS=3
PGC_POSITION_SIZING=equal_slots

# Agent artifacts stay inside the project workspace.
PGC_AGENT_ARTIFACT_DIR=data/agents/tradingagents

# Prototype image generation. Keep the real API key only in local .env.
PGC_IMAGE_API_KEY=
PGC_IMAGE_BASE_URL=https://tokenx24.com/v1
PGC_IMAGE_MODEL=gpt-image-2
PGC_IMAGE_SIZE=1536x1024
PGC_IMAGE_QUALITY=high
PGC_IMAGE_OUTPUT_FORMAT=png
PGC_IMAGE_BACKGROUND=opaque
PGC_IMAGE_MODERATION=auto
